#!/usr/bin/env bash

set -euo pipefail

if [ -t 0 ]; then
  input_cmd=(tmux save-buffer -)
else
  input_cmd=(cat)
fi

has_wayland_clipboard() {
  [ -n "${WAYLAND_DISPLAY:-}" ] && [ -n "${XDG_RUNTIME_DIR:-}" ] && command -v wl-copy >/dev/null 2>&1
}

has_x11_clipboard() {
  [ -n "${DISPLAY:-}" ]
}

if has_wayland_clipboard; then
  "${input_cmd[@]}" | wl-copy
  exit 0
fi

if has_x11_clipboard && command -v xclip >/dev/null 2>&1; then
  "${input_cmd[@]}" | xclip -selection clipboard
  exit 0
fi

if has_x11_clipboard && command -v xsel >/dev/null 2>&1; then
  "${input_cmd[@]}" | xsel --clipboard --input
  exit 0
fi

if command -v pbcopy >/dev/null 2>&1; then
  "${input_cmd[@]}" | pbcopy
  exit 0
fi

# Avoid Kitty's terminal-driven clipboard protocol from inside tmux. On this
# setup it is the common crash path for tmux server copy/paste operations.
if [ -z "${TMUX:-}" ] && command -v kitten >/dev/null 2>&1; then
  "${input_cmd[@]}" | kitten clipboard
  exit 0
fi

tmux display-message "No supported clipboard copy tool found (install wl-clipboard, xclip, or xsel)"
