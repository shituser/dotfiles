# OSX
font_family JetBrainsMono Nerd Font Mono Light
italic_font JetBrainsMono Nerd Font Mono Light Italic
bold_font JetBrainsMono Nerd Font Mono Regular
bold_italic_font JetBrainsMono Nerd Font Mono Italic
# LINUX
#font_family FiraCode Nerd Font Reg
#italic_font FiraCode Nerd Font Reg
#bold_font FiraCode Nerd Font Medium
#bold_italic_font FiraCode Nerd Font Medium
#font_family VictorMono NF Medium
#italic_font VictorMono NF Medium Italic
#bold_font VictorMono NF SemiBold
#bold_italic_font VictorMono NF SemiBold Italic
#font_family JetBrainsMono NF Regular
#italic_font JetBrainsMono NF Italic
#bold_font JetBrainsMono NF SemiBold
#bold_italic_font JetBrainsMono NF SemiBold Italic
#font_family Operator Mono Book
#italic_font Operator Mono Book Italic
#bold_font Operator Mono Medium
#bold_italic_font Operator Mono Medium Italic

# LINUX
#font_size 13
#hide_window_decorations yes
#initial_window_width 2560
#initial_window_height 1440
#
# OSX
font_size 16

adjust_line_height 200%

cursor_shape block
shell_integration no-cursor
cursor_blink_interval 0

enable_audio_bell 0
window_padding_width 5


# BEGIN_KITTY_THEME
# Adapta Nokto Maia
include current-theme.conf
# END_KITTY_THEME
